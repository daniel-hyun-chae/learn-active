{
  "name": "learn-active-dev",
  "dockerComposeFile": "../docker-compose.devcontainer.yml",
  "service": "dev",
  "workspaceFolder": "/workspaces/learn-active",
  "forwardPorts": [4000, 4100, 54321, 54324],
  "overrideCommand": false,
  "remoteUser": "node",
  "containerUser": "node",
  "updateRemoteUserUID": false,
  "remoteEnv": {
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "CI": "true",
    "PLAYWRIGHT_BROWSERS_PATH": "/home/node/.cache/ms-playwright"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "corepack prepare pnpm@9.12.2 --activate && pnpm install && sh scripts/devcontainer-install-opencode.sh && stripe --version && PLAYWRIGHT_BROWSERS_PATH=/home/node/.cache/ms-playwright pnpm exec playwright install chromium",
  "postStartCommand": "sh -lc 'if [ ! -d node_modules/.pnpm ]; then pnpm install; fi'",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind",
    "source=${localWorkspaceFolderBasename}-bashhistory,target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.netrc,target=/home/node/.netrc,type=bind",
    "source=${localWorkspaceFolderBasename}-opencode-data,target=/home/node/.local/share/opencode,type=volume",
    "source=${localWorkspaceFolderBasename}-opencode-state,target=/home/node/.local/state/opencode,type=volume",
    "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/home/node/.local/share/opencode/auth.json,type=bind",
    "source=${localWorkspaceFolderBasename}-ms-playwright,target=/home/node/.cache/ms-playwright,type=volume"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "remote.autoForwardPorts": false,
        "remote.restoreForwardedPorts": false
      },
      "extensions": ["sst-dev.opencode"]
    }
  }
}
