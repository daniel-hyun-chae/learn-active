{
  "name": "@app/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/verify-route-tree.mjs && pnpm exec vite dev",
    "build": "node ../../scripts/verify-route-tree.mjs && pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "start": "pnpm run preview",
    "deploy:pages": "pnpm exec wrangler pages deploy dist --project-name course-web",
    "deploy:pages:staging": "pnpm exec wrangler pages deploy dist --project-name course-web-staging",
    "deploy:pages:prod": "pnpm exec wrangler pages deploy dist --project-name course-web",
    "lint": "pnpm -w exec eslint ."
  },
  "dependencies": {
    "@app/shared-config": "workspace:*",
    "@app/shared-graphql": "workspace:*",
    "@app/shared-i18n": "workspace:*",
    "@app/shared-tokens": "workspace:*",
    "@app/shared-ui": "workspace:*",
    "@app/shared-utils": "workspace:*",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-router": "1.131.50",
    "graphql-request": "^7.1.0",
    "@lexical/history": "^0.41.0",
    "@lexical/link": "^0.41.0",
    "@lexical/list": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "lexical": "^0.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.0.0",
    "wrangler": "3.95.0"
  }
}
