{
  "name": "@app/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tsx watch src/index.ts",
    "dev:worker": "pnpm exec wrangler dev --config wrangler.jsonc --port 4000",
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "deploy:worker": "pnpm exec wrangler deploy --config wrangler.jsonc",
    "deploy:worker:staging": "pnpm exec wrangler deploy --config wrangler.jsonc --name course-api-staging --var APP_ENV:staging",
    "deploy:worker:prod": "pnpm exec wrangler deploy --config wrangler.jsonc --name course-api --var APP_ENV:production",
    "lint": "pnpm exec eslint src --max-warnings 0"
  },
  "dependencies": {
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.13.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.7.1",
    "jose": "^5.9.6",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.6",
    "wrangler": "3.95.0",
    "tsx": "^4.18.0",
    "typescript": "^5.6.3"
  }
}
