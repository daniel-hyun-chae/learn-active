{
  "name": "learning-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:cleanup": "node scripts/cleanup-dev-stack.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --check .",
    "setup": "node scripts/setup-env.mjs",
    "verify:setup": "node scripts/verify-startup.mjs",
    "smoke:local": "node scripts/smoke-local.mjs",
    "db:up": "node scripts/dev-db.mjs up",
    "db:status": "node scripts/dev-db.mjs status",
    "db:logs": "node scripts/dev-db.mjs logs",
    "validate:deploy-env": "node scripts/validate-deploy-env.mjs",
    "test:unit": "node --test tests/unit",
    "test:integration": "node --test tests/integration",
    "test:e2e": "node --test tests/e2e/smoke.test.js && node scripts/run-publisher-e2e.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "playwright": "^1.55.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.12",
    "typescript": "^5.6.3"
  }
}
